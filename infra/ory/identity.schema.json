{
  "$id": "https://seam.tacklines.com/identity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SeamUser",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "Email",
          "maxLength": 320,
          "ory.com/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              },
              "webauthn": {
                "identifier": true
              },
              "totp": {
                "account_name": true
              },
              "passkey": {
                "display_name": true
              }
            },
            "recovery": {
              "via": "email"
            },
            "verification": {
              "via": "email"
            }
          }
        },
        "name": {
          "type": "string",
          "title": "Display Name",
          "maxLength": 256
        }
      },
      "required": ["email"],
      "additionalProperties": false
    }
  }
}
