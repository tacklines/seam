{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "outDir": "dist-server",
    "noEmit": false,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "allowImportingTsExtensions": false,
    "types": ["node"]
  },
  "include": [
    "src/server/mcp.ts",
    "src/server/http.ts",
    "src/server/store.ts",
    "src/lib/session-store.ts",
    "src/lib/yaml-validator-server.ts",
    "src/schema/types.ts"
  ]
}
