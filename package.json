{
  "name": "seam",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "server:dev": "npx tsx src/server/mcp.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "server": "npx tsx src/server/http.ts",
    "mcp": "npx tsx src/server/mcp.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@shoelace-style/shoelace": "^2.20.1",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "elkjs": "^0.11.0",
    "js-yaml": "^4.1.0",
    "lit": "^3.2.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/web-components-vite": "^10.2.13",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1",
    "storybook": "^10.2.13",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  }
}
